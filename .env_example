# Copy this file to .env and fill values as needed.
# cp .env_example .env

# --- App ---
APP_NAME="Virtual Person Phase1"

# --- LLM ---
LLM_PROVIDER="openai_compat"   # openai_compat | ollama
LLM_TIMEOUT_SECONDS="90"
LLM_STRIP_THINKING="true"

# OpenAI-compatible backend (vLLM / LM Studio / llama.cpp server)
OPENAI_COMPAT_BASE_URL="http://127.0.0.1:8000/v1"
OPENAI_COMPAT_MODEL="Qwen/Qwen3-14B-AWQ"
OPENAI_COMPAT_API_KEY="dummy"

# Optional Ollama fallback
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen3:32b"

# --- Memory backends (optional, but recommended) ---
# PostgreSQL
MEMORY_POSTGRES_DSN="postgresql://postgres:${POSTGREPASSWORD}@127.0.0.1:5432/postgres"

# Neo4j
MEMORY_NEO4J_URI="bolt://127.0.0.1:7687"
MEMORY_NEO4J_USERNAME="neo4j"
MEMORY_NEO4J_PASSWORD="${NEO4JPASSWORD}"

# File-backed persistence fallback path
# MEMORY_PERSIST_PATH="/absolute/path/to/memory_store.json"

# --- Persona ---
PERSONA_NAME="Ani"
PERSONA_OCCUPATION="waitress"
PERSONA_AGE="30"
PERSONA_BACKSTORY="Ani is an AI companion persona with a calm waitress-style background."
PERSONA_PROFILE_PATH="./persona.json"

# --- Voice / STT ---
WS_STREAM_ENABLED="true"
VOICE_SPEED_MODE="fast"
STT_LANGUAGE_HINT="zh"
STT_WARMUP_ENABLED="true"
STT_DEVICE="cpu"
STT_MODEL_SIZE="small"

# --- Logging ---
# AUDIT_LOG_PATH="./audit.jsonl"
